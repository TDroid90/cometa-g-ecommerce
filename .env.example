# Opcion A: usar una Google Sheet publica por ID.
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_PRODUCTOS_ID=
GOOGLE_SHEETS_USERS_ID=
GOOGLE_SHEETS_VENTAS_ID=
GOOGLE_DRIVE_COMPRAS_FOLDER_ID=

# Opcion privada recomendada: service account de Google Cloud.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Alternativa si preferis separar campos.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Opcion B: usar URLs CSV publicadas para cada hoja.
GOOGLE_SHEETS_LAYOUT_URL=
GOOGLE_SHEETS_PRODUCTOS_URL=

# Si tu hoja usa nombres distintos, cambia estos valores.
GOOGLE_SHEETS_LAYOUT_NAME=LAYOUT
GOOGLE_SHEETS_PRODUCTOS_NAME=PRODUCTOS
GOOGLE_SHEETS_MENU_CATEGORIAS_NAME=MENU_CAT_MAR
GOOGLE_SHEETS_CATALOGO_LOG_NAME=CATALOGO_LOG
CATALOG_USD_RATE=1470

# Revalidacion en segundos para datos leidos desde Google Sheets.
GOOGLE_SHEETS_REVALIDATE_SECONDS=60

# Vercel Blob para imagenes publicas de catalogo.
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=

# Payway checkout link. El SDK usa developer para sandbox o production para real.
PAYWAY_ENVIRONMENT=developer
PAYWAY_PUBLIC_KEY=
PAYWAY_PRIVATE_KEY=
PAYWAY_SITE_ID=
PAYWAY_ESTABLISHMENT_NUMBER=
PAYWAY_TERMINAL_ID=
PAYWAY_CUIT=
PAYWAY_COMPANY=COMETA G
PAYWAY_USER=COMETA G Web
PAYWAY_TEMPLATE_ID=1
PAYWAY_INSTALLMENTS=1,3,6
PAYWAY_PAYMENT_METHOD_ID=1
PAYWAY_AUTH_3DS=true
NEXT_PUBLIC_SITE_URL=https://www.cometag.store
